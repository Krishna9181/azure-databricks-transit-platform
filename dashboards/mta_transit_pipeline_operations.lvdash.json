{
  "datasets": [
    {
      "name": "silver_events",
      "displayName": "Silver Valid Events",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mta_rtransit.silver.fact_trip_delay_event\n",
        "WHERE\n",
        "  is_valid = true"
      ],
      "columns": [
        {
          "displayName": "hour_utc",
          "description": "Hour of day (UTC) extracted from event timestamp",
          "expression": "HOUR(`event_ts`)"
        }
      ]
    },
    {
      "name": "gold_kpi",
      "displayName": "Gold Route KPIs",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mta_rtransit.gold.route_delay_kpi_enriched"
      ],
      "columns": [
        {
          "displayName": "Avg Delay (s)",
          "description": "Avg delay with N/A fallback",
          "expression": "COALESCE(CAST(ROUND(`avg_delay_sec`, 1) AS STRING), 'N/A')"
        },
        {
          "displayName": "P95 Delay (s)",
          "description": "P95 delay with N/A fallback",
          "expression": "COALESCE(CAST(ROUND(`p95_delay_sec`, 1) AS STRING), 'N/A')"
        }
      ]
    }
  ],
  "pages": [
    {
      "name": "0ab9ecc8",
      "displayName": "Page 1",
      "layout": [
        {
          "widget": {
            "name": "total_trip_updates",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "gold_kpi",
                  "fields": [
                    {
                      "name": "sum(trip_update_cnt)",
                      "expression": "SUM(`trip_update_cnt`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "title": "Total Trip Updates",
                "showTitle": true
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "sum(trip_update_cnt)",
                  "format": {
                    "type": "number-plain",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 0
                    },
                    "abbreviation": "compact"
                  },
                  "displayName": "Total Updates"
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 4,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "active_routes",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "gold_kpi",
                  "fields": [
                    {
                      "name": "countdistinct(route_id)",
                      "expression": "COUNT(DISTINCT `route_id`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "title": "Active Routes",
                "showTitle": true
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "countdistinct(route_id)",
                  "format": {
                    "type": "number-plain",
                    "decimalPlaces": {
                      "type": "exact",
                      "places": 0
                    },
                    "abbreviation": "none"
                  },
                  "displayName": "Active Routes"
                }
              }
            }
          },
          "position": {
            "x": 4,
            "y": 0,
            "width": 4,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "latest_data",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "gold_kpi",
                  "fields": [
                    {
                      "name": "max(kpi_date)",
                      "expression": "MAX(`kpi_date`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "frame": {
                "title": "Latest Data",
                "showTitle": true
              },
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "max(kpi_date)",
                  "displayName": "Latest Date"
                }
              }
            }
          },
          "position": {
            "x": 8,
            "y": 0,
            "width": 4,
            "height": 3
          }
        },
        {
          "widget": {
            "name": "trip_updates_by_route",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "gold_kpi",
                  "fields": [
                    {
                      "name": "route_short_name",
                      "expression": "`route_short_name`"
                    },
                    {
                      "name": "sum(trip_update_cnt)",
                      "expression": "SUM(`trip_update_cnt`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "title": "Trip Updates by Route",
                "showTitle": true
