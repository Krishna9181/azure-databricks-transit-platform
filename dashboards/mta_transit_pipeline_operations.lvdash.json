                      "by": "y-reversed"
                    }
                  }
                },
                "y": {
                  "fieldName": "sum(trip_update_cnt)",
                  "axis": {
                    "hideTitle": true
                  },
                  "displayName": "Trip Updates",
                  "scale": {
                    "type": "quantitative"
                  }
                },
                "color": {
                  "fieldName": "route_short_name",
                  "legend": {
                    "hide": true
                  },
                  "displayName": "Route",
                  "scale": {
                    "type": "categorical"
                  }
                },
                "label": {
                  "show": true
                }
              }
            }
          },
          "position": {
            "x": 0,
            "y": 3,
            "width": 6,
            "height": 6
          }
        },
        {
          "widget": {
